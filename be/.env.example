API_PORT=3000
ALLOWED_ORIGINS=http://localhost:3000

MONGO_USER=root
MONGO_PASSWORD=root
MONGO_DB=home-inventory
MONGO_PORT=27017
MONGO_URI=mongodb://root:root@localhost:27017/home-inventory?authSource=admin

REDIS_HOST=localhost
REDIS_PORT=6379

S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=home-inventory
S3_REGION=us-east-1
S3_PORT=9000
S3_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_VIEW_DOMAIN=http://localhost:9000

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
