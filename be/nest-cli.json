{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": ["@nestjs/swagger"],
    "assets": [
      { "include": "libs/mail/templates/**/*", "outDir": "dist" },
      { "include": "api/report/assets/fonts/**/*", "outDir": "dist" }
    ],
    "watchAssets": true
  }
}
